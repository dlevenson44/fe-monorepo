{
    "private": true,
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "lint": "turbo run lint",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "commit": "bash commit.sh",
        "precommit": "pnpm husky install && pnpm lint && pnpm build",
        "storybook:build": "turbo run build --filter storybook",
        "storybook:dev": "turbo run dev --filter storybook",
        "storybook:lint": "turbo run lint --filter storybook",
        "storybook:start": "cd apps/storybook && pnpm run storybook",
        "algos:dev": "turbo run dev --filter algorithms",
        "algos:build": "turbo run build --filter algorithms",
        "algos:lint": "turbo run lint --filter algorithms",
        "algos:start": "turbo run start --filter algorithms"
    },
    "devDependencies": {
        "@dev/commitizen-config-custom": "*",
        "@dev/eslint-config-custom": "*",
        "@dev/tsconfig": "*",
        "commitizen": "~4.3.0",
        "eslint": "~8.48.0",
        "husky": "~8.0.3",
        "prettier": "~3.0.3",
        "turbo": "latest"
    },
    "packageManager": "pnpm@8.6.10",
    "engines": {
        "node": ">=20.9.0"
    },
    "resolutions": {
        "@types/react": "~18.0.0"
    },
    "workspaces": [
        "apps/*",
        "packages/**/*"
    ],
    "config": {
        "commitizen": {
            "path": "@dev/commitizen-config-custom"
        },
        "commitlint": {}
    },
    "dependencies": {
        "@changesets/cli": "~2.26.2"
    }
}
